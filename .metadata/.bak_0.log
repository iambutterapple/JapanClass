public class IfEx08 {

	public static void main(String[] args) {
		
		Scanner sc = new Scanner(System.in);
		System.out.print("알파벳 한 문자 입력: ");
		int a = sc.next().charAt(0);
		
		if((a >= 'A' && a <= 'Z')) {
			(a >= 'a' && a <= 'z')
			System.out.println(a);
		}
		
	}

}

