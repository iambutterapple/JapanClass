	public static void main(String[] args) {
		
		Scanner sc = new Scanner(System.in);
		System.out.print("알파벳 한 문자 입력: ");
		char a = sc.next().charAt(0);
		
		if((a >= 'A' && a <= 'Z')) {
			(a >= 'a' && a <= 'z')
			System.out.println(a);
		}
		
	}

}

