package com.classex.ex01;
import java.util.*;
/*
 * 
 *  문]
 *  		MonthSchedule 클래스에 Day 객체배열과 적절한 필드, 메소드를 작성하고,
 *  		실행결과와 같이 3가지 기능을 가진 프로그램을 작성하시오.
 *  
 *  		MonthSchedule 클래스에는 생성자, input(),view(),finish(),run() 메소드를 만들고
 *  		main()메소드에서 실행하여 메뉴를 출력
 *  
 * 			실행결과
 * 
 *  		이번달 스케줄 관리 프로그램
 *  		할일(입력 : 1, 보기:2, 종료:3 ) : 1
 *  		날짜(1~30) : 1
 *  		할일(빈칸없이입력) : 자바공부
 *  		
 *  		할일(입력 : 1, 보기:2, 종료:3 ) : 2
 *  		1일의 할일은 자바공부 입니다.
 *  
 *  		할일(입력 : 1, 보기:2, 종료:3 ) : 3
 *  		프로그램을 종료합니다.
 *  		
 * 
 * */
//Day.java	private String work;//하루에 할 일을 입력받는 문자열
public class MonthSchedule {
	
	//필드선언
	//날짜 필드
	private int apri_day;
	//Day 클래스 객체 배열 선언
	Day day_p = new Day();
	//입력은 스캐너
	Scanner sc = new Scanner(System.in);
	public MonthSchedule(int day) {
		this.apri_day = day;
	}
	//날짜 입력
	public void input() {
//		Test
//		System.out.println(!check);
		boolean check = true;

		while(!check) {
			System.out.print("날짜(1~30) : ");
			this.apri_day = sc.nextInt();
			System.out.println(apri_day);
			if(this.apri_day<1 && this.apri_day>30&&Objects.isNull(apri_day))
				check = false;
		}
		
	}
	public void run() {
		String input_number;
		do {
			System.out.println("이번달 스케줄 관리 프로그램");
			System.out.print("할일(입력 : 1, 보기:2, 종료:3 ) : ");
			input_number = sc.next().trim();
			switch (input_number) {
			case "1":
				input();
				break;
			case "2":
				view();
				break;
			default:
				break;
			}
			
			
		} while (!input_number.equals("3"));
	}
	public void view() {
		System.out.println("view");
	}
	public void finish() {
		
	}

	
	public static void main(String[] args) {
		//4월 한달의 기준으로 한다.
		MonthSchedule apri = new MonthSchedule(30);
		apri.run();
	}
}
