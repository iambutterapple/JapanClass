package com.arraytwoex;

/*
 * 	문제)	주민번호를 입력받아 올바른 주민번호인지를 검증하는 프로그램을 구현하시오.
 * 			
 * 			12 34 56-abcdefg
 * 
 * 			12 -> 태어난 년도, 34 -> 월, 56 -> 일
 * 			a -> 성별(1900 -> 1, 2 : 2000 -> 3, 4 : 1800 -> 9, 0)
 * 					남성: 9, 1, 3		여성: 0, 2, 4
 * 			b -> 주민번호를 등록한 지역
 * 			c, d -> (시, 구), (도, 군)를 의미
 * 			e, f -> 동, 읍, 면을 의미함
 * 			g -> 주민번호가 올바른지를 판별하는 숫자를 의미함
 * 
 * 			마지막 숫자 g를 판별하는 공식
 * 			hap = 0;
 * 			hap = hap + 주민번호 첫번째 자리(1) * 2;
 * 			hap = hap + 주민번호 두번째 자리(2) * 3;
 * 			hap = hap + 주민번호 세번째 자리(3) * 4;
 * 			hap = hap + 주민번호 네번째 자리(4) * 5;
 * 			hap = hap + 주민번호 다섯번째 자리(5) * 6;
 * 			hap = hap + 주민번호 여섯번째 자리(6) * 7;
 * 			-	: 계산에서 제외시킴
 * 			hap = hap + 주민번호 여덟번째 자리(a) * 8;
 * 			hap = hap + 주민번호 아홉번째 자리(b) * 9;
 * 			hap = hap + 주민번호 열번째 자리(c) * 2;
 * 			hap = hap + 주민번호 열한번째 자리(d) * 3;
 * 			hap = hap + 주민번호 열두번째 자리(e) * 4;
 * 			hap = hap + 주민번호 열세번째 자리(f) * 5;
 * 
 * 			temp = (int)(hap / 11.0f) * 11.0f + 11.0f - hap;
 * 			temp1 = temp - (int)(temp / 10.0f) * 10.0f;
 */

import java.io.*;
public class ArrayEx06 {

	public static void main(String[] args) throws IOException{
		BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
		
		// 변수와 배열선언
		String name ="";
		int jumin[] = new int[14];
		boolean right = false;
		
		// 이름을 입력 받음
		System.out.print("이름 입력: ");
		name = br.readLine();
		
		do {
			right = false;
			System.out.print("주민번호 입력(000000-0000000): ");
			for(int i = 0; i < jumin.length; i++) {
				jumin[i] = System.in.read() - 48; // 아스키 코드 뺌
			}
			System.in.skip(2);
			
			// 월의 범위체크
			if(jumin[2] * 10 + jumin[3] > 12) {
				System.out.println("태어난 달은 12월 보다 클 수 없습니다.");
				continue;
			}
			else if(jumin[4] * 10 + jumin[5] > 31) {
				// 일의 범위체크
				System.out.println("태어난 일은 31일보다 클 수 없습니다.");
				continue;
			}
			else if(jumin[7] != 9 && jumin[7] != 0 && jumin[7] != 1 && jumin[7] != 2 &&
					// 성별 체크
					jumin[7] != 3 && jumin[7] != 4) {
				System.out.println("성별을 나타내는 숫자는 9, 0, 1, 2, 3, 4 중 하나이어야 합니다.");
				continue;
			}
			
			// 주민번호가 올바른지를 판별한다.
			int hap = 0;
			int cre = 2;
			float temp = 0.0f, temp1 = 0.0f;
			
			for(int i = 0; i < jumin.length - 1; i++) {
				if(i == 6) {
					continue;
				}
				hap = hap + jumin[i] * cre;
				cre++;
				if(cre == 10) {
					cre = 2;
				}
			}
			
			temp = (int)(hap / 11.0f) * 11.0f + 11.0f - hap;
			temp1 = temp - (int)(temp / 10.0f) * 10.0f;
			if(temp1 != jumin[13]) {
				System.out.println("주민번호 검증 숫자가 올바르지 않습니다.");
				continue;
			}
			right = true;
		} while(!right);
		
		System.out.println();
		System.out.println("이름: " + name);
		System.out.println("주민번호: ");
		for(int i = 0; i < jumin.length; i++) {
			if(i == 6) {
				System.out.println("-");
				continue;
			}
			// jumin 배열에 저장된 주민번호를 출력한다.
			System.out.print(jumin[i]);
		}
		System.out.println();
		// 생년월일
		System.out.print("생년월일: ");
		int year = 0;
		int month = 0;
	} // end main

} // end class
