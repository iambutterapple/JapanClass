package com.forextwo;

public class Study03 {

	public static void main(String[] args) {
		
		for(int i = 0; i <= 10; i++) {
			for(int j = 0; j <= (i - 1); j++) {
				System.out.print(" ");
			}
			for(int z = i; z <= 10 - i; z++) {
				System.out.print("*");
			}
		}
		System.out.println();
	}

}
