package com.forextwo;

public class ForTwoEx02 {

	public static void main(String[] args) {
		
		for(char i = 'A'; i <= 'Z'; i++) {
			for(char j = 0; j <= (i - 66); ++j) {
				System.out.print("  ");
			}
			for(char c = i; c <= 'Z' - (i - 65); ++c) {
				System.out.print(c);
			}
			System.out.println();
			
		}
	}
}

