package com.classex.ex01;
import java.util.*;
/*
 * 문]
 * 		Dictionary 클래스와 DicApp 클래스를 구현하여 다음과 같이 출력하는 프로그램을 구현하시오.
 * 		
 * 		한영단어 검색 프로그램
 * 		한글 단어 : 희망
 * 		희망은 hope
 * 		한글 단어 : 아가
 * 		아가는 저의 사전에 없습니다.
 * 		한글 단어 : 아기
 * 		아기는 baby
 * 		한글 단어 : 그만
 * 		프로그램을 종료합니다.
 * 
 * 
 * */
public class DicApp {

	
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		
		System.out.println("한영단어 검색 프로그램");
		while(true) {
			System.out.print("한글 :");
			String kor = sc.next();
			
			if(kor.equals("그만"))
			{
				System.out.println("프로그램을 종료합니다.");
				
			}
				return;

			
		}
	}
}
