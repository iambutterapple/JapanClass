package com.arraytwoex;

import java.io.*;
public class NewEx01 {

	public static void main(String[] args) throws IOException{
		BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
		
		int a = 0;
		int b = 0;
		char c = ' ';
		
		System.out.print("입력: ");
		a = System.in.read();
		System.in.skip(2);
		System.out.print("입력: ");
		b = System.in.read();
		System.in.skip(2);
		
		c = (char)a + b;
		System.out.println(c);
	}

}
