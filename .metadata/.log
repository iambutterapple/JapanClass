 * 
 * 			정수입력: -12
 * 			-12 -> 음수
 * 
 * 			정수입력: 12
 * 			12 -> 양수
 * 
 * 			정수입력: 0
 * 			0 -> 0
 */

import java.util.*;
public class IfEx13 {

	public static void main(String[] args) {
		
		Scanner sc = new Scanner(System.in);
		
		System.out.print("정수입력: ");
		int a = sc.nextInt();
		String b;
		
		if(a < 0) {
			b = "음수";
		} else if (a == 0) {
			b = "0";
		} else (a > 0) {
			b = "양수";
		}
		
		b = (a < 0) ? "음수" : (a == 0) ? "0" : "양수";
		System.out.println(b);
	}
}

