package com.arraytwoex;

import java.io.*;
public class ArrayEx10_1 {

	public static void main(String[] args) throws IOException{
		BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
		
		String[] subname = {"국어", "영어", "수학"};
		int[][] sub = new int[2][subname.length + 2];
		// 0: 국어, 1: 영어, 2: 수학 3: 합계, 4: 석차
		float[] avg = new float[2]; // 학생별 평균
		
		for(int k = 0; k < sub.length; k++) { // 사람: 행
			for(int i = 0; i < sub[k].length - 2; i++) {
				// 각 과목별 점수 입력
				do {
					System.out.print(subname[i] + "점수: ");
					sub[k][i] = Integer.parseInt(br.readLine());
				} while(sub[k][i] < 0 || sub[k][i] > 100);
				// 한 사람당 과목별 점수의 합계를 구함
				sub[k][sub[k].length - 2] += sub[k][i];
			}
			// 사람별 평균을 구함
			avg[k] = sub[k][sub[k].length - 2] / (float)(sub[k].length - 2);
			// 석차를 초기화함
			sub[k](sub[k].length - 1)
		}
		
	}

}

