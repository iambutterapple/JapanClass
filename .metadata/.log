package com.exam;

/*
 *	문제) 1 ~ 99까지의 정수를 입력받고 입력받은 정수 중 3, 6, 9 중 하나가 있는 경우
 *			"박수 짝"을 출력하고, 두개가 있는 경우 "박수 짝짝"을 출력하는 프로그램을 구현하시오.
 *			
 *			13 -> 박수 짝
 *			36 -> 박수 짝짝
 *		
 *			결과 출력
 *			1 ~ 99 사이의 정수 입력: 36
 *			박수 짝짝
 */

import java.util.*;
public class Exam06 {

	public static void main(String[] args) {
		
		Scanner sc = new Scanner(System.in);
		System.out.print("정수 입력: ");
		int a = sc.nextInt();
		if(a > 99) {
			System.out.println("두 자리의 정수를 다시 입력해주세요.");
		}
		
		int ten = a / 10;
		int il = a % 10;
		
		
		if(il == 3 || il == 6 || il == 9) {
			(ten == 3 && il == 3)
		} else if((ten == 3 && il == 3) || (ten == 6 && il == 6) || (ten == 9 && il == 9)) {
			System.out.println("박수 짝짝");
		}
	}

}

