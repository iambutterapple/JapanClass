		v.add(new Nation("멕시코", "멕시코시티"));
		v.add(new Nation("스페인", "리스본"));
		v.add(new Nation("프랑스", "파리"));
		v.add(new Nation("영국", "런던"));
		v.add(new Nation("그리스", "아테네"));
		v.add(new Nation("독일", "베를린"));
		v.add(new Nation("일본", "도쿄"));
